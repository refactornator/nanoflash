# NanoFlash — environment configuration
# Copy this file to .env and fill in the values.

# Required: Gemini API key (get a free key at https://aistudio.google.com)
GEMINI_API_KEY=

# Optional: Model overrides (these are the defaults)
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash

# Optional: Agent name (used as trigger word and in responses)
ASSISTANT_NAME=Sergey

# Optional: Your local timezone (e.g. America/New_York, Europe/London, Asia/Tokyo)
TZ=
